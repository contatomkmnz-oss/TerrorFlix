generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Movie {
  id            String          @id
  title         String
  slug          String          @unique
  description   String
  year          Int
  rating        String?
  duration      Int?
  posterImage   String          @map("poster_image")
  bannerImage   String          @map("banner_image")
  movieUrl      String?         @map("movie_url")
  trailerUrl    String?         @map("trailer_url")
  isFeatured    Boolean         @default(false) @map("is_featured")
  isPublished   Boolean         @default(true) @map("is_published")
  totalViews    Int             @default(0) @map("total_views")
  bannerObjectPosition String?  @map("banner_object_position")
  highlightedHomeSection String? @map("highlighted_home_section")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  categories    MovieCategory[]
  heroBanners   HeroBanner[]
}

model Series {
  id            String            @id
  title         String
  slug          String            @unique
  description   String
  year          Int
  rating        String?
  posterImage   String            @map("poster_image")
  bannerImage   String            @map("banner_image")
  isFeatured    Boolean           @default(false) @map("is_featured")
  isPublished   Boolean           @default(true) @map("is_published")
  totalViews    Int               @default(0) @map("total_views")
  bannerObjectPosition String?    @map("banner_object_position")
  highlightedHomeSection String?  @map("highlighted_home_section")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  episodes      Episode[]
  categories    SeriesCategory[]
  heroBanners   HeroBanner[]
}

model Episode {
  id             String   @id
  seriesId       String   @map("series_id")
  series         Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  seasonNumber   Int      @map("season_number")
  episodeNumber  Int      @map("episode_number")
  title          String
  description    String?
  videoUrl       String   @map("video_url")
  thumbnail      String?
  duration       Int?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([seriesId])
}

enum CategoryType {
  movie
  series
  both
}

model Category {
  id        String           @id @default(cuid())
  name      String
  slug      String           @unique
  type      CategoryType     @default(both)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  movies    MovieCategory[]
  series    SeriesCategory[]
}

model MovieCategory {
  id         String   @id @default(cuid())
  movieId    String   @map("movie_id")
  categoryId String   @map("category_id")
  movie      Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([movieId, categoryId])
}

model SeriesCategory {
  id         String   @id @default(cuid())
  seriesId   String   @map("series_id")
  categoryId String   @map("category_id")
  series     Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([seriesId, categoryId])
}

model HeroBanner {
  id             String   @id @default(cuid())
  title          String
  subtitle       String?
  description    String?
  image          String
  linkedMovieId  String?  @map("linked_movie_id")
  linkedSeriesId String?  @map("linked_series_id")
  customUrl      String?  @map("custom_url")
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  linkedMovie    Movie?   @relation(fields: [linkedMovieId], references: [id], onDelete: SetNull)
  linkedSeries   Series?  @relation(fields: [linkedSeriesId], references: [id], onDelete: SetNull)
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}
